<?php
// listado_estudiantes.php - Muestra todos los estudiantes registrados

require_once 'config.php';

// Consultar todos los estudiantes
try {
    $sql = "SELECT id, nombre, apellido, email, telefono, 
                   TO_CHAR(fecha_nacimiento, 'DD/MM/YYYY') as fecha_nacimiento,
                   TO_CHAR(fecha_registro, 'DD/MM/YYYY HH24:MI') as fecha_registro
            FROM estudiantes 
            ORDER BY id DESC";
    
    $result = $pdo->query($sql);
    $estudiantes = $result->fetchAll();
} catch (PDOException $e) {
    $error = "Error al consultar: " . $e->getMessage();
    $estudiantes = [];
}
?>

